# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP (for confirmation & launch emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-smtp-password
SMTP_FROM=your@email.com

# Launch notify endpoint protection
LAUNCH_NOTIFY_SECRET=your-secret-here

# Same Postgres database as the oystr app (read-only queries, e.g. top
# moonshots on the landing page). Copy the value from oystr/.env.
DATABASE_URL=postgresql://user:password@host:5432/db

# The oystr product app (auth, feed, launch, moonshot pages...). All in-app
# links on the landing page point here.
NEXT_PUBLIC_APP_URL=https://app.oystr.ca
